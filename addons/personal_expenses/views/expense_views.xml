<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_personal_expense_open_form" model="ir.actions.server">
        <field name="name">Editar gasto</field>
        <field name="model_id" ref="model_personal_expense"/>
        <field name="state">code</field>
        <field name="code"><![CDATA[
action = {
    "type": "ir.actions.act_window",
    "name": "Gasto",
    "res_model": "personal.expense",
    "res_id": record.id,
    "view_mode": "form",
    "target": "current",
}
        ]]></field>
    </record>

    <record id="action_personal_expense_delete" model="ir.actions.server">
        <field name="name">Eliminar gasto</field>
        <field name="model_id" ref="model_personal_expense"/>
        <field name="state">code</field>
        <field name="code"><![CDATA[
record.unlink()
action = {
    "type": "ir.actions.client",
    "tag": "reload",
}
        ]]></field>
    </record>

    <record id="view_personal_expense_list" model="ir.ui.view">
        <field name="name">personal.expense.list</field>
        <field name="model">personal.expense</field>
        <field name="arch" type="xml">
            <list string="Gastos Personales">
                <field name="date" string="Fecha"/>
                <field name="name" string="Descripción"/>
                <field name="amount" string="Monto" sum="Total:"/>
                <field name="category_id" string="Categoría"/>
                <button name="%(action_personal_expense_open_form)d"
                        type="action"
                        string="Editar"
                        class="btn-primary"
                        icon="fa-pencil"/>
                <button name="%(action_personal_expense_delete)d"
                        type="action"
                        string="Eliminar"
                        confirm="¿Seguro que deseas eliminar este gasto?"
                        class="btn-danger"
                        icon="fa-trash"/>
            </list>
        </field>
    </record>

    <record id="view_personal_expense_kanban" model="ir.ui.view">
        <field name="name">personal.expense.kanban</field>
        <field name="model">personal.expense</field>
        <field name="arch" type="xml">
            <kanban default_group_by="date">
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <div class="text-muted">
                                <field name="date"/>
                            </div>
                            <div>
                                <strong>Monto:</strong>
                                <field name="amount"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_personal_expense_form" model="ir.ui.view">
        <field name="name">personal.expense.form</field>
        <field name="model">personal.expense</field>
        <field name="arch" type="xml">
            <form string="Gasto Personal">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="amount"/>
                        <field name="category_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>