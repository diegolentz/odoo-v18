<odoo>
    <!-- custom list view -->
    <record id="custom_list_view" model="ir.ui.view">
        <field name="name">custom.crm.lead.list</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="class" add="custom_crm_red_headers" separator=" "/>
                <attribute name="create">true</attribute>
            </xpath>

            <!-- Quitar todos los botones del header (alternativa más agresiva) -->
            <!-- <xpath expr="//list/header/button" position="replace"/> -->



            <!-- Quitar botón Email de cada fila -->
            <xpath expr="//list/button[@type='action' and @icon='fa-envelope']" position="replace"/>

            <!-- Quitar botón Snooze -->
            <xpath expr="//list/button[@name='action_snooze']" position="replace"/>

            <!-- Agregar campo de teléfono al lado del nombre -->
            <xpath expr="//list//field[@name='name']" position="after">
                <field name="phone"/>
            </xpath>
        </field>
    </record>
</odoo>
